<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Edit the appointment</h2>
    <form id="editAppointment" data-appointment-id="<%=appointmentId%>">
        <label>Appointment Date</label>
        <input type="date" name="appointmentDate" required>
        <br><br>

        <label>Start Time</label>
        <input type="time" name="startTime" required >
        <br><br>

        <label>End Time</label>
        <input type="time" name="endTime" required>
        <br><br>

        <label>Symptoms</label>
        <br>
        <textarea name="symptoms" rows="4" cols="40" placeholder="Enter symptoms" required></textarea>
        <br><br>

        <label>Patient Message</label>
        <br>
        <textarea name="patientMessage" rows="4" cols="40" placeholder="Additional information" required></textarea>
        <br><br>

        <button type="submit" id="btn">
            Edit Appointment
        </button>
    </form>
    <script src="/js/editAppointment.js"></script>
</body>

</html>