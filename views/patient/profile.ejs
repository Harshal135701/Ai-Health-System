<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>GET ROUTE for patient profile </h2>
    <form id="completeProfile">
        <label>Age</label>
        <input type="number" name="age" required>
        <br>

        <label>gender</label>
        <select name="gender" required>
            <option value="male">male</option>
            <option value="female">female</option>
            <option value="other">other</option>
        </select>
        <br>

        <label>bloodGroup</label>
        <input type="text" name="bloodGroup" required>
        <br>

        <label>allergies</label>
        <input type="text" name="allergies" required>
        <br>
        <label>medicalHistory</label>
        <input type="text" name="medicalHistory" required>
        <br>
        <label>address</label>
        <input type="text" name="address" required>
        <br>
        <button type="submit">Create</button>
    </form>
    <script src="/js/completePatientProfile.js"></script>
</body>

</html>