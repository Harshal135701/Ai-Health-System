<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Appointments</title>
</head>

<body>

    <h1>All Appointments</h1>

    <form action="/doctor/appointments" method="GET">

        <select name="status" onchange="this.form.submit()">

            <option value="all" <%=selectedStatus==="all" ? "selected" : "" %>>
                All Appointments
            </option>

            <option value="today" <%=selectedStatus==="today" ? "selected" : "" %>>
                Today's Appointments
            </option>

            <option value="pending" <%=selectedStatus==="pending" ? "selected" : "" %>>
                Pending Appointments
            </option>

            <option value="confirmed" <%=selectedStatus==="confirmed" ? "selected" : "" %>>
                Confirmed Appointments
            </option>

            <option value="rejected" <%=selectedStatus==="rejected" ? "selected" : "" %>>
                Rejected Appointments
            </option>

            <option value="completed" <%=selectedStatus==="completed" ? "selected" : "" %>>
                Completed Appointments
            </option>

        </select>

    </form>

    <% if (appointments.length===0) { %>

        <h3>No appointments found.</h3>

        <% } else { %>

            <% appointments.forEach(function(appointment){ %>

                <hr>

                <h3>Patient Details</h3>

                <p>
                    <strong>Name:</strong>
                    <%= appointment.patientId.name %>
                </p>

                <p>
                    <strong>Email:</strong>
                    <%= appointment.patientId.email %>
                </p>

                <p>
                    <strong>Phone:</strong>
                    <%= appointment.patientId.phoneNo %>
                </p>

                <h3>Appointment Details</h3>

                <p>
                    <strong>Date:</strong>
                    <%= appointment.appointmentDate.toDateString() %>
                </p>

                <p>
                    <strong>Start Time:</strong>
                    <%= appointment.startTime %> minutes
                </p>

                <p>
                    <strong>End Time:</strong>
                    <%= appointment.endTime %> minutes
                </p>

                <p>
                    <strong>Status:</strong>
                    <%= appointment.appointmentStatus %>
                </p>

                <p>
                    <strong>Symptoms:</strong>
                    <%= appointment.symptoms %>
                </p>

                <p>
                    <strong>Patient Message:</strong>
                    <%= appointment.patientMessage %>
                </p>

                <p>
                    <strong>Consultation Fee:</strong>
                    ₹<%= appointment.consultationFee %>
                </p>

                <form class="statusChangeForm" data-appointment-id="<%=appointment._id%>">
                    <select name="appointmentStatus">
                        <option value="confirmed" <%=appointment.appointmentStatus==="confirmed" ? "selected" : "" %>
                            >confirmed</option>
                        <option value="rejected" <%=appointment.appointmentStatus==="rejected" ? "selected" : "" %>
                            >rejected</option>
                        <option value="completed" <%=appointment.appointmentStatus==="completed" ? "selected" : "" %>
                            >completed</option>


                    </select>
                    <button type="submit">Change Status</button>
                </form>

                <% }) %>

                    <% } %>

                        <script src="/js/changeStatus.js"></script>
</body>

</html>